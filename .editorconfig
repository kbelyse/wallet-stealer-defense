# Enforces LF + final newline at editor save time across all major editors.
# Editor-side companion to .gitattributes for the 2026-Q2 wallet-stealer
# incident hardening.
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{md,markdown}]
trim_trailing_whitespace = false
